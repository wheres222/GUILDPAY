# Public frontend config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&scope=bot%20applications.commands&permissions=268823632
NEXT_PUBLIC_DISCORD_CLIENT_ID=
NEXT_PUBLIC_DISCORD_BOT_PERMISSIONS=268823632

# Auth.js (Discord OAuth)
AUTH_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Optional server-side bot install check in guild selector
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_BOT_USER_ID=

# Optional server-side API base (fallbacks to NEXT_PUBLIC_API_BASE_URL)
API_BASE_URL=http://localhost:3000/api
